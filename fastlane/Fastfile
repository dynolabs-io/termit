default_platform(:ios)

platform :ios do
  desc "Build + upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"),
      duration: 1200,
      in_house: false
    )

    build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "io.dynolabs.termit"
    ) + 1
    increment_build_number(
      build_number: build_number,
      xcodeproj: "Termit.xcodeproj"
    )

    build_app(
      project: "Termit.xcodeproj",
      scheme: "Termit",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/output",
      output_name: "Termit.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TERMIT_TEAM_ID']}"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/output/Termit.ipa",
      skip_waiting_for_build_processing: true,
      changelog: "Termit build #{build_number} — auto-uploaded from #{ENV['GITHUB_SHA']}"
    )
  end
end
